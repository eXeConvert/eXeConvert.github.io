{
  "name": "execonvert",
  "version": "0.1.0-beta.10",
  "private": false,
  "type": "module",
  "bin": {
    "execonvert": "./bin/execonvert.js"
  },
  "files": [
    "bin",
    "dist/cli",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "build:cli": "node ./scripts/build-cli.mjs",
    "build:all": "npm run build:web && npm run build:cli",
    "preview": "vite preview",
    "check": "npm run check:web && npm run check:cli",
    "check:web": "tsc -p tsconfig.json --noEmit",
    "check:cli": "tsc -p tsconfig.cli.json --noEmit",
    "cli": "node ./bin/execonvert.js",
    "prepack": "npm run build:cli"
  },
  "dependencies": {
    "docx": "^9.6.0",
    "fflate": "^0.8.2",
    "html-to-pdfmake": "^2.5.33",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jspdf": "^4.2.0",
    "katex": "^0.16.33",
    "mammoth": "^1.11.0",
    "markdown-it": "^14.1.1",
    "markdown-it-texmath": "^1.0.0",
    "mathml-to-latex": "^1.5.0",
    "mathml2omml": "^0.5.0",
    "omml2mathml": "^1.3.0",
    "pdfmake": "^0.3.6",
    "linkedom": "^0.18.12",
    "temml": "^0.13.1",
    "tsx": "^4.21.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/markdown-it": "^14.1.2",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
